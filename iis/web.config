<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Rule 1: Proxy /api/* requests to NestJS backend on port 5000 -->
        <rule name="ReverseProxy-API" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:5000/api/{R:1}" />
        </rule>
        <!-- Rule 2: Proxy everything else to Next.js frontend on port 4200 -->
        <rule name="ReverseProxy-Frontend" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:4200/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
