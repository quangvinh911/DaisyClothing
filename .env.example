# ========================
# DaisyDaily Environment
# ========================

# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/daisydaily?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Admin (initial seed)
ADMIN_EMAIL="admin@daisydaily.com"
ADMIN_PASSWORD="changeme123"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:4200"

# Google Analytics
GA_TRACKING_ID=""
